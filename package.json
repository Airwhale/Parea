{
  "name": "parea",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Parea Wander group adventure agent.",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "dev:chat": "tsx src/spectrumApp.ts",
    "dev:terminal": "tsx src/spectrumTerminal.ts",
    "judges:demo": "tsx src/spectrumApp.ts",
    "full-loop:smoke": "tsx src/fullLoopSmoke.ts",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "adventure:smoke": "tsx src/adventureSmoke.ts",
    "xtrace:smoke": "tsx src/xtraceSmoke.ts"
  },
  "dependencies": {
    "@butterbase/sdk": "^2.4.0",
    "@xtraceai/memory": "^0.2.1",
    "dotenv": "^17.4.2",
    "rocketride": "^1.2.0",
    "spectrum-ts": "^1.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
